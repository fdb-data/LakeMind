# LakeMind v0.2.0 环境变量模板 — 复制为 .env 后修改

# ---- 镜像配置 ----
LAKEMIND_REGISTRY=ghcr.io/fdb-data/lakemind
LAKEMIND_VERSION=0.2.0
POSTGRES_AGE_VERSION=16.4-age-v0.2.0
PULL_POLICY=missing

# ---- 第三方镜像 ----
SEAWEEDFS_IMAGE=chrislusf/seaweedfs:3.101
VALKEY_IMAGE=valkey/valkey:8.0.9
RAY_IMAGE=rayproject/ray:2.41.0-py312

# ---- SeaweedFS ----
SEAWEEFS_S3_PORT=8333
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin123456

# ---- PostgreSQL 16 + AGE ----
PG_DB=lakemind
PG_USER=lakemind
PG_PASSWORD=lakemind_pass

# ---- Ray ----
RAY_HEAD_CPUS=4
RAY_WORKER_CPUS=4

# ---- 嵌入式引擎 ----
LANCE_DB_URI=lance:///data/lance

# ---- LLM Model Gateway ----
MAAS_API_KEY=<your-maas-api-key>

# ---- Master Key (base64-encoded 32 bytes) ----
LAKEMIND_MASTER_KEY=<your-master-key>

# ---- v0.2.0 Control Plane ----
LAKEMIND_V2_AUTH=0
SERVER_API_KEY=<your-server-api-key>
