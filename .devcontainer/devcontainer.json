{
  "name": "LakeMind",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "version": "latest",
      "enableNonRootDocker": "true"
    },
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "forwardPorts": [
    10823,
    10824,
    8401,
    8402,
    8403,
    8500,
    3000,
    8265,
    9100
  ],
  "postCreateCommand": "bash .devcontainer/bootstrap.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter",
        "redhat.vscode-yaml",
        "ms-azuretools.vscode-docker",
        "ms-azuretools.vscode-docker-compose",
        "GitHub.copilot"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.formatting.provider": "black",
        "files.exclude": {
          "**/__pycache__": true,
          "**/.pytest_cache": true
        }
      }
    }
  },
  "remoteEnv": {
    "DOCKER_BUILDKIT": "0"
  },
  "mounts": [
    "source=lakemind-dev-data,target=/workspaces/LakeMind/data,type=volume"
  ],
  "secrets": {
    "MAAS_API_KEY": {
      "description": "LLM API key for ModelServing (required for ASR/LLM features)"
    },
    "LAKEMIND_MASTER_KEY": {
      "description": "Master key for LakeMind Server (required for auth)"
    }
  }
}
