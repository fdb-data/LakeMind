# LakeMind MVP 环境变量示例。复制为 .env 后按需修改。

# ---- SeaweedFS ----
SEAWEEDFS_IMAGE=chrislusf/seaweedfs:latest
SEAWEEFS_MASTER_PORT=9333
SEAWEEFS_VOLUME_PORT=8080
SEAWEEFS_FILER_PORT=8888
SEAWEEFS_S3_PORT=8333
# S3 凭证（与 config/seaweedfs/s3.json 保持一致）
S3_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin123456

# ---- Apache Gravitino ----
GRAVITINO_IMAGE=apache/gravitino:1.3.0
GRAVITINO_PORT=8090
GRAVITINO_ICEBERG_REST_PORT=9001
GRAVITINO_MEM=-Xms1g -Xmx2g -XX:MaxMetaspaceSize=512m

# ---- Dragonfly（短期记忆，Redis 兼容）----
DRAGONFLY_IMAGE=docker.dragonflydb.io/dragonflydb/dragonfly:latest
DRAGONFLY_PORT=6379
DRAGONFLY_PASSWORD=

# ---- 嵌入式引擎（Agent 进程内使用，非容器）----
# Lance/LanceDB：多 Agent 共享的 Lance 数据目录（单机挂载同一卷）
LANCE_DB_URI=lance:///data/lance
# DuckDB / Daft / PyIceberg 通过 S3 凭证访问 SeaweedFS
