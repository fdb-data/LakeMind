# LakeMind v0.1.0 环境变量示例。复制为 .env 后按需修改。

# ---- SeaweedFS (S3 对象存储) ----
SEAWEEDFS_IMAGE=chrislusf/seaweedfs:latest
SEAWEEFS_MASTER_PORT=9333
SEAWEEFS_VOLUME_PORT=8080
SEAWEEFS_FILER_PORT=8888
SEAWEEFS_S3_PORT=8333
S3_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin123456

# ---- PostgreSQL 16 + AGE (统一元数据 + 图存储) ----
PG_DB=lakemind
PG_USER=lakemind
PG_PASSWORD=lakemind_pass
PG_PORT=5432

# ---- Valkey (TTL KV 缓存, Redis 兼容, BSD 3-Clause) ----
VALKEY_IMAGE=valkey/valkey:8.0
VALKEY_PORT=6379

# ---- Ray 集群 (分布式计算) ----
RAY_IMAGE=lakemind/ray:2.41.0-py3.12
RAY_DASHBOARD_PORT=8265
RAY_HEAD_CPUS=4
RAY_WORKER_CPUS=4

# ---- REST API 网关 ----
SERVER_API_KEY=lakemind-internal-api-key

# ---- 租户密钥加密主密钥 (AES-256, 32 bytes base64) ----
# 生成: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
LAKEMIND_MASTER_KEY=

# ---- LLM Model Gateway (ModelArts / DeepSeek) ----
# 从 https://console.huaweicloud.com/modelarts-maas/ 获取 API Key
MAAS_API_KEY=your-maas-api-key-here
